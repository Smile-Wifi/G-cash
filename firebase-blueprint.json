{
  "entities": {
    "User": {
      "title": "User",
      "description": "A digital wallet user profile.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phoneNumber": { "type": "string" },
        "displayName": { "type": "string" },
        "balance": { "type": "number" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "phoneNumber", "balance", "role"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A wallet transaction record.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["send", "receive", "cash-in", "cash-out", "payment"] },
        "status": { "type": "string", "enum": ["success", "pending", "failed"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "description": { "type": "string" }
      },
      "required": ["amount", "type", "status", "timestamp"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A user notification.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["transaction", "security", "system"] },
        "read": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "message", "type", "read", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile and balance."
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "History of all transactions."
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications."
    }
  }
}
