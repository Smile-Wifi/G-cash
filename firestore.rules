rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: userId (UID)
    // Fields:
    //   - uid: string (required)
    //   - email: string (required, email format)
    //   - phoneNumber: string (required)
    //   - displayName: string (optional)
    //   - balance: number (required, non-negative)
    //   - role: string (required, 'user' or 'admin')
    //   - createdAt: timestamp (required)
    //
    // Collection: transactions
    // Document ID: transactionId
    // Fields:
    //   - senderId: string (optional, UID)
    //   - receiverId: string (optional, UID)
    //   - amount: number (required, positive)
    //   - type: string (required, enum)
    //   - status: string (required, enum)
    //   - timestamp: timestamp (required)
    //   - description: string (optional)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "kaptenlanaja2024@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'phoneNumber', 'balance', 'role', 'createdAt']) &&
             data.uid is string &&
             data.email is string &&
             data.phoneNumber is string &&
             data.balance is number && data.balance >= 0 &&
             data.role in ['user', 'admin'] &&
             data.createdAt is timestamp;
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['amount', 'type', 'status', 'timestamp']) &&
             data.amount is number && data.amount > 0 &&
             data.type in ['send', 'receive', 'cash-in', 'cash-out', 'payment'] &&
             data.status in ['success', 'pending', 'failed'] &&
             data.timestamp is timestamp;
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['userId', 'title', 'message', 'type', 'read', 'timestamp']) &&
             data.userId is string &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.message is string && data.message.size() > 0 && data.message.size() < 500 &&
             data.type in ['transaction', 'security', 'system'] &&
             data.read is bool &&
             data.timestamp is timestamp;
    }

    // Rules for users
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == 'user';
      allow update: if isAdmin() || (isOwner(userId) && 
                                     request.resource.data.role == resource.data.role && 
                                     request.resource.data.balance == resource.data.balance &&
                                     isValidUser(request.resource.data));
    }

    // Rules for transactions
    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.receiverId || isAdmin());
      allow create: if isAuthenticated() && isValidTransaction(request.resource.data) && 
                    (request.auth.uid == request.resource.data.senderId || request.auth.uid == request.resource.data.receiverId || isAdmin());
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Rules for notifications
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated() && isValidNotification(request.resource.data) && (request.auth.uid == request.resource.data.userId || isAdmin());
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin()) && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
    }
  }
}
